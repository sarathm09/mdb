{
  "name": "@sarathm09/mdb",
  "version": "1.0.5",
  "type": "module",
  "license": "MIT",
  "description": "CLI tool to browse, view, edit and present markdown files in a web-based file explorer",
  "repository": {
    "type": "git",
    "url": "https://github.com/sarathm09/mdb.git"
  },
  "keywords": [
    "markdown",
    "browser",
    "editor",
    "presentation",
    "cli"
  ],
  "files": [
    "dist/",
    "!dist/*.map"
  ],
  "bin": {
    "markdown-browser": "./dist/cli.mjs",
    "mdb": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "npx tsx build.ts",
    "prepublishOnly": "npx tsx build.ts",
    "start": "npx tsx src/cli.ts",
    "dev": "npx vite dev --config vite.config.ts",
    "dev:server": "npx tsx --watch src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "open": "^10"
  },
  "devDependencies": {
    "@codemirror/lang-markdown": "^6",
    "@codemirror/language-data": "^6",
    "@codemirror/theme-one-dark": "^6",
    "@hono/node-server": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/dompurify": "^3",
    "codemirror": "^6",
    "dompurify": "^3",
    "esbuild": "^0.28.0",
    "happy-dom": "^20.9.0",
    "highlight.js": "^11",
    "hono": "^4",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "marked": "^17",
    "marked-highlight": "^2",
    "mermaid": "^11",
    "playwright": "^1.59.1",
    "reveal.js": "^6.0.0",
    "svelte": "^5",
    "tsx": "^4.21.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
