{
  "name": "markdown-browser",
  "version": "1.0.0",
  "module": "src/cli.ts",
  "type": "module",
  "license": "MIT",
  "description": "CLI tool to browse, view, edit and present markdown files in a web-based file explorer",
  "repository": {
    "type": "git",
    "url": "https://github.com/sarathm09/mdb.git"
  },
  "keywords": ["markdown", "browser", "editor", "presentation", "cli"],
  "files": ["src/", "plugins/", "dist/", "build.ts", "tsconfig.json"],
  "engines": {
    "bun": ">=1.0.0"
  },
  "bin": {
    "markdown-browser": "./src/cli.ts"
  },
  "scripts": {
    "build": "bun run build.ts",
    "postinstall": "bun run build.ts",
    "start": "bun run src/cli.ts",
    "dev": "bun run build.ts && bun --hot src/cli.ts"
  },
  "dependencies": {
    "dompurify": "^3",
    "highlight.js": "^11",
    "hono": "^4",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "marked": "^17",
    "marked-highlight": "^2",
    "mermaid": "^11",
    "open": "^10",
    "reveal.js": "^6.0.0"
  },
  "devDependencies": {
    "@codemirror/lang-markdown": "^6",
    "@codemirror/language-data": "^6",
    "@codemirror/theme-one-dark": "^6",
    "@types/bun": "latest",
    "@types/dompurify": "^3",
    "codemirror": "^6",
    "playwright": "^1.59.1",
    "svelte": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
