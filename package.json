{
  "name": "@sarathm09/mdb",
  "version": "1.0.4",
  "module": "src/cli.ts",
  "type": "module",
  "license": "MIT",
  "description": "CLI tool to browse, view, edit and present markdown files in a web-based file explorer",
  "repository": {
    "type": "git",
    "url": "https://github.com/sarathm09/mdb.git"
  },
  "keywords": [
    "markdown",
    "browser",
    "editor",
    "presentation",
    "cli"
  ],
  "files": [
    "src/",
    "dist/",
    "bin/",
    "!dist/*.map"
  ],
  "bin": {
    "markdown-browser": "./bin/cli.cjs",
    "mdb": "./bin/cli.cjs"
  },
  "scripts": {
    "build": "bun run build.ts",
    "prepublishOnly": "bun run build.ts",
    "start": "bun run src/cli.ts",
    "dev": "bun run build.ts && bun --hot src/cli.ts"
  },
  "dependencies": {
    "hono": "^4",
    "open": "^10"
  },
  "devDependencies": {
    "@codemirror/lang-markdown": "^6",
    "@codemirror/language-data": "^6",
    "@codemirror/theme-one-dark": "^6",
    "@types/bun": "latest",
    "@types/dompurify": "^3",
    "codemirror": "^6",
    "dompurify": "^3",
    "highlight.js": "^11",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "marked": "^17",
    "marked-highlight": "^2",
    "mermaid": "^11",
    "playwright": "^1.59.1",
    "reveal.js": "^6.0.0",
    "svelte": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public"
  }
}
